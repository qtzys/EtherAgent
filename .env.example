# 最核心 Agent v0.2 · 配置文件模板
# 复制为 .env 并填入真实值（.env 不要提交到 git）

# ============================================
# LLM 配置（RealLLM 用）
# ============================================

# Anthropic API key（或 MiniMax 代理的 key）
# 去控制台获取：https://console.anthropic.com/  或  https://api.minimax.chat/
ANTHROPIC_API_KEY=

# 自定义 base_url（用 MiniMax 代理时填这个）
# 示例：https://api.minimax.chat  或  https://api.MiniMax.com
ANTHROPIC_BASE_URL=

# 模型名
# Anthropic 官方：claude-sonnet-4-6, claude-opus-4-8, claude-haiku-4-5-20251001
# MiniMax：MiniMax-M3 等
LLM_MODEL=claude-sonnet-4-6

# 单次最大 token
LLM_MAX_TOKENS=4096

# ============================================
# 其他配置（后续 P0 用）
# ============================================

# SQLite 数据库路径（默认当前目录）
# DB_PATH=agent.db

# 审计日志级别（debug/info/warn/error）
# AUDIT_LEVEL=info