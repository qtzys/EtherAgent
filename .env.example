# 最核心 Agent v0.2 · 配置文件模板
# 复制为 .env 并填入真实值（.env 不要提交到 git）

# ============================================
# LLM 配置（RealLLM 用）
# ============================================

# Anthropic API key（或 MiniMax 代理的 key）
# ⚠️ 永远不要把真实 key 写到任何会被提交的文件里（包括 .env 的 git 提交）
# 去控制台获取：https://console.anthropic.com/  或  https://api.minimaxi.com/
ANTHROPIC_API_KEY=sk-cp-RJ11mbJJDKhfYY0fNQgD4DCz6Np8p5If79g7_QaOBOuRYH3h1fYd-X-ET7IuuYgv7t_WOqCte8PoFgRxfvLQjEtgiiI3A3NiDQN1ew1WGRxvxFUTtF3qrbY

# 自定义 base_url（用 MiniMax 代理时填这个）
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# 模型名
# MiniMax：MiniMax-M3
# Anthropic 官方：claude-sonnet-4-6, claude-opus-4-8, claude-haiku-4-5-20251001
LLM_MODEL=MiniMax-M3

# 单次最大 token
LLM_MAX_TOKENS=128000

# ============================================
# 其他配置（后续 P0 用）
# ============================================

# SQLite 数据库路径（默认当前目录）
# DB_PATH=agent.db

# 审计日志级别（debug/info/warn/error）
# AUDIT_LEVEL=info